				{
					"name": "Get Personalised Feed",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/feed?page=1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"feed"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								}
							]
						}
					}
