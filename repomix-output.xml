                    >
                      {member.email}
                    </Text>
                  </View>
                  <ExternalLink size={16} color={colors.text.tertiary} />
                </TouchableOpacity>

                <View style={styles.divider} />

                <TouchableOpacity
                  style={styles.infoRow}
