              {/* Title & Directive */}
              <View style={styles.directiveSection}>
                <Text style={styles.directiveTitle}>CONFIRM REMOVAL</Text>
                <Text style={styles.mainTitle}>
                  Permanently Purge{'\n'}This Resource?
                </Text>
              </View>

              {/* Resource Detail Card */}
              <View style={styles.resourceCard}>
