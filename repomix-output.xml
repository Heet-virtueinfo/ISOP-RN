# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

$RNFirebaseAsStaticFramework = true

target 'ISOP_RN' do
  use_frameworks! :linkage => :static
  
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # Targets that use React macros (RCT_EXPORT_MODULE, RCT_EXTERN, etc.) must not be
    # compiled as modules, because Xcode 26's strict module boundary enforcement prevents
    # macro definitions from crossing framework module boundaries. Setting DEFINES_MODULE=NO
    # ensures these pods compile as plain static libraries without module maps.
    rnfb_targets = ['RNFBMessaging', 'RNFBApp', 'RNFBFirestore', 'RNFBAuth', 'RNFBStorage',
                    'RNFBDatabase', 'RNFBFunctions', 'RNFBCrashlytics', 'RNFBAnalytics',
                    'RNFBDynamicLinks', 'RNFBInAppMessaging', 'RNFBPerformance', 'RNFBRemoteConfig']

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

        if rnfb_targets.include?(target.name)
          # Disable module compilation for RNFB pods so React macros are visible
          config.build_settings['DEFINES_MODULE'] = 'NO'
        end
      end
    end

    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )
  end
end
