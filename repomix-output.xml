                  ]}
                  onPress={() =>
                    setSelectedEvent(prev => (prev === title ? null : title))
                  }
                >
                  <Text
                    style={[
                      styles.filterChipText,
                      selectedEvent === title && styles.filterChipTextActive,
                    ]}
