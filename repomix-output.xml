                  {search || selectedEvent
                    ? 'Adjust your parameters to broaden the search.'
                    : 'Awaiting first executive enrollment.'}
                </Text>
              </View>
            )}
          </View>
        )}
      </ScrollView>

      <MemberDetailModal
        visible={isModalVisible}
        onClose={() => {
          setIsModalVisible(false);
